# VM2 — Automação (n8n + PostgreSQL + Redis)
# Copie para .env e preencha os valores reais
# NUNCA commitar o .env com valores reais

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=mude-para-uma-senha-forte-aqui

# Redis
REDIS_PASSWORD=mude-para-uma-senha-forte-aqui

# n8n
N8N_HOST=n8n.jpxdigital.com.br
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=mude-para-uma-senha-forte-aqui

# Segredo compartilhado com VM1 (deve ser igual ao N8N_INTERNAL_SECRET da VM1)
N8N_INTERNAL_SECRET=mude-para-um-segredo-longo-e-aleatorio-aqui
