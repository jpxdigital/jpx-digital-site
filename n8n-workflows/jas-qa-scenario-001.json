      ],
      "parameters": {
        "url": "http://n8n:5678/webhook/jas-intake",
        "method": "POST",
        "options": {
          "timeout": 30000
        },
        "jsonBody": "={\n  \"event\": \"messages.upsert\",\n  \"instance\": \"jpx-jas\",\n  \"data\": {\n    \"key\": {\n      \"remoteJid\": \"5500000000001@s.whatsapp.net\",\n      \"fromMe\": false,\n      \"id\": \"{{ $('Definir Teste').item.json.test_msg_id }}\"\n    },\n    \"message\": {\"conversation\": \"Assessment Executivo\"},\n    \"messageType\": \"conversation\",\n    \"pushName\": \"JAS QA Bot\",\n    \"messageTimestamp\": 1720000000\n  }\n}",
        "sendBody": true,
