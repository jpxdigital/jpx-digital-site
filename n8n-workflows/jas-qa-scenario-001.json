      "parameters": {
        "jsCode": "const ts = Date.now();\nreturn [{ json: {\n  test_phone: '+5500000000001',\n  test_phone_raw: '5500000000001',\n  scenario_id: 'QA-001',\n  started_at: new Date().toISOString(),\n  test_msg_id: 'QA001_' + ts\n}}];"
