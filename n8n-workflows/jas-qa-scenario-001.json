    {
      "id": "qa001-smoke-eval",
      "name": "Avaliar Smoke",
      "type": "n8n-nodes-base.code",
      "position": [
        1100,
        300
      ],
      "parameters": {
        "jsCode": "let failures = [];\nlet details = {};\n\ntry {\n  const db = $('Smoke DB').item.json;\n  details.db = (db.ok === 1 || db.ok === '1') ? 'OK' : 'FAIL';\n  if (details.db !== 'OK') failures.push('PostgreSQL');\n} catch(e) { failures.push('PostgreSQL'); details.db = 'ERROR'; }\n\ntry {\n  const hs = $('Smoke HubSpot').item.json;\n  details.hubspot = (hs.results !== undefined) ? 'OK' : 'FAIL';\n  if (details.hubspot !== 'OK') failures.push('HubSpot');\n} catch(e) { failures.push('HubSpot'); details.hubspot = 'ERROR'; }\n\ntry {\n  const tg = $('Smoke Telegram').item.json;\n  details.telegram = (tg.ok === true) ? 'OK' : 'FAIL';\n  if (details.telegram !== 'OK') failures.push('Telegram');\n} catch(e) { failures.push('Telegram'); details.telegram = 'ERROR'; }\n\nconst smoke_pass = failures.length === 0;\nconst definir = $('Definir Teste').item.json;\n\nconst abort_msg = failures.length > 0\n  ? ('QA ABORTADO\\nServicos indisponiveis: ' + failures.join(', '))\n  : 'OK';\nconst abort_msg_safe = JSON.stringify(abort_msg).slice(1, -1);\n\nreturn [{ json: { ...definir, smoke_pass, smoke_failures: failures, smoke_details: details, abort_msg_safe } }];"
      },
      "typeVersion": 2
    },
