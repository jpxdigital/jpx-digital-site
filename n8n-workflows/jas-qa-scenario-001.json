      "parameters": {
        "query": "SELECT (SELECT COUNT(*)::int FROM jas_sessions WHERE telefone = '+5500000000001') as session_ok, (SELECT COUNT(*)::int FROM jas_events WHERE session_id IN (SELECT session_id FROM jas_sessions WHERE telefone = '+5500000000001')) as events_count, (SELECT COUNT(*)::int FROM jas_message_dedup WHERE message_id = '{{ $('Definir Teste').item.json.test_msg_id }}') as dedup_ok",
        "options": {},
        "operation": "executeQuery"
      },
