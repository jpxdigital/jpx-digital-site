        "specifyBody": "json",
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-jas-secret",
              "value": "={{ $vars.JAS_WEBHOOK_SECRET }}"
            }
          ]
        }
      },
      "typeVersion": 4.1
    },
