    {
      "id": "qa001-n08",
      "name": "Calcular Resultado",
      "type": "n8n-nodes-base.code",
      "position": [
        2640,
        300
      ],
      "parameters": {
        "jsCode": "const definir=$('Definir Teste').item.json;\nconst db=$('Verificar DB').item.json;\nconst hsContact=$('Verificar Contato HubSpot').item.json;\nconst hsDeal=$('Verificar Deal HubSpot').item.json;\nconst started=new Date(definir.started_at);\nconst elapsed=((Date.now()-started.getTime())/1000).toFixed(1);\nconst contact_id=((hsContact.results||[])[0]||{}).id||null;\nconst deal_id=((hsDeal.results||[])[0]||{}).id||null;\nconst checks=[\n  ['Sessao criada (DB)',(db.session_ok||0)>=1],\n  ['Eventos registrados (min 2)',(db.events_count||0)>=2],\n  ['Mensagem dedupada (DB)',(db.dedup_ok||0)>=1],\n  ['Contato HubSpot criado',(hsContact.total||0)>=1],\n  ['Deal HubSpot criado',(hsDeal.total||0)>=1],\n];\nconst passed=checks.filter(function(c){return c[1];}).length;\nconst failed=checks.length-passed;\nconst ok=failed===0;\nconst lines=[];\nlines.push('<b>JAS-QA</b> Cenario 001');\nlines.push('<b>STATUS: '+(ok?'PASS ✅':'FAIL ❌')+'</b> Tempo: '+elapsed+'s ('+passed+'/'+checks.length+')');\nfor(var i=0;i<checks.length;i++){\n  lines.push((checks[i][1]?'☑':'☒')+' '+checks[i][0]);\n}\nif(failed>0){lines.push('⚠️ Verificar execucoes n8n');}\nconst report_tg=lines.join('\\n');\nconst report_safe=JSON.stringify(report_tg).slice(1,-1);\nreturn [{json:{report:report_tg,report_safe:report_safe,status:ok?'PASS':'FAIL',passed:passed,failed:failed,elapsed:elapsed,contact_id:contact_id,deal_id:deal_id}}];"
      },
      "typeVersion": 2
    },
