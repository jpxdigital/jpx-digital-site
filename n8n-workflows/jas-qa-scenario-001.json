    {
      "id": "qa001-n07",
      "name": "Verificar Deal HubSpot",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2420,
        300
      ],
      "parameters": {
        "url": "https://api.hubapi.com/crm/v3/objects/deals/search",
        "method": "POST",
        "options": {
          "timeout": 30000
        },
        "jsonBody": "{\"filterGroups\": [{\"filters\": [{\"propertyName\": \"dealname\", \"operator\": \"EQ\", \"value\": \"JAS QA Bot \\u2014 WhatsApp JAS\"}]}], \"properties\": [\"dealname\", \"dealstage\"]}",
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "headerParameters": {
          "parameters": [
            {
