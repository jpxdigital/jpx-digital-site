    {
      "id": "intake-estado-check",
      "name": "Verificar Estado",
      "type": "n8n-nodes-base.if",
      "position": [
        1500,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
