    {
      "id": "a1b2c3d4-0001-0001-0001-000000000019",
      "name": "Resolver Sessão",
      "type": "n8n-nodes-base.code",
      "position": [
        1760,
        140
      ],
      "parameters": {
        "jsCode": "// Normaliza dados da sessão independente do caminho executado\nlet correlation_id, session_id, estado, contexto;\ntry {\n  const s = $('Criar Sessão').item.json;\n  correlation_id = s.correlation_id;\n  session_id     = s.session_id;\n  estado         = s.estado;\n  contexto       = s.contexto;\n} catch(e) {\n  const s = $('Buscar Sessão').item.json;\n  correlation_id = s.correlation_id;\n  session_id     = s.session_id;\n  estado         = s.estado;\n  contexto       = s.contexto;\n}\nreturn [{ json: { correlation_id, session_id, estado, contexto } }];"
      },
      "typeVersion": 2
    },
