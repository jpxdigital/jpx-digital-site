                "name": "filter.operator.equals",
                "type": "number",
                "operation": "equals"
              },
              "leftValue": "={{$json.is_dup}}",
              "rightValue": 0
            }
          ]
        }
      },
      "typeVersion": 2
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000007",
      "name": "Registrar Dedup",
