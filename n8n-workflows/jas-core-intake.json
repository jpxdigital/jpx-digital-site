    {
      "id": "intake-processar-estado",
      "name": "Processar Estado",
      "type": "n8n-nodes-base.code",
      "position": [
        1500,
        500
      ],
      "parameters": {
        "jsCode": "const session = $('Resolver Sessão').item.json;\nconst norm    = $('Extrair e Normalizar').item.json;\nconst phone_raw = norm.phone_raw;\nconst rawText   = (norm.text || '').trim();\nconst text      = rawText.toLowerCase();\nconst estado    = session.estado || 'MENU';\nconst pushName  = norm.push_name || 'visitante';\nconst sessionId = session.session_id;\n\nconst calUrl = $vars.JAS_CALCOM_LINK_ASSESSMENT || 'https://cal.com/jpxdigital';\nconst MENU_MSG = 'Para direcionarmos seu atendimento, escolha uma opção:\\n\\n1️⃣ Assessment Executivo\\n2️⃣ Cloud e Modernização\\n3️⃣ Backup e Disaster Recovery\\n4️⃣ FinOps\\n5️⃣ Segurança e Resiliência\\n6️⃣ Falar com um especialista';\n\nlet resposta = '';\nlet novoEstado = estado;\nlet contextoObj = {};\nlet notificarDono = false;\n\nif (estado === 'MENU') {\n  const match1 = /^1$|assessment/i.test(text);\n  const match2 = /^2$|cloud|moderni/i.test(text);\n  const match3 = /^3$|backup|disaster|recovery/i.test(text);\n  const match4 = /^4$|finops|fin ops|custo|cloud cost/i.test(text);\n  const match5 = /^5$|seguran|resili|cibern/i.test(text);\n  const match6 = /^6$|especialista|falar|humano/i.test(text);\n\n  if (match6) {\n    resposta = 'Entendido, ' + pushName + '! 👤 Vou notificar o João Martins agora.\\n\\nEle entrará em contato pessoalmente em breve. Aguarde!';\n    novoEstado = 'HUMAN_TAKEOVER';\n    contextoObj = { servico: 'Especialista' };\n    notificarDono = true;\n  } else {\n    const servicoMap = [\n      [match1, 'Assessment Executivo'],\n      [match2, 'Cloud e Modernização'],\n      [match3, 'Backup e Disaster Recovery'],\n      [match4, 'FinOps'],\n      [match5, 'Segurança e Resiliência']\n    ];\n    const found = servicoMap.find(function(s){ return s[0]; });\n    if (found) {\n      const servico = found[1];\n      resposta = 'Ótima escolha! Você selecionou *' + servico + '*. ✅\\n\\nO João Martins oferece um *Assessment Executivo gratuito* de 30 minutos — ele analisa seu cenário e já apresenta recomendações práticas.\\n\\nGostaria de agendar agora? Responda *sim* para receber o link. 📅';\n      novoEstado = 'AGENDAMENTO';\n      contextoObj = { servico: servico };\n    } else {\n      resposta = 'Desculpe, não entendi sua escolha. 😊\\n\\n' + MENU_MSG;\n    }\n  }\n\n} else if (estado === 'AGENDAMENTO') {\n  if (/^s$|^sim$|^quero$|^ok$|^yes$|^claro$|^pode$|^vamos$|^bora$/.test(text)) {\n    resposta = 'Perfeito! Aqui está o link para escolher o horário:\\n\\n👉 ' + calUrl + '\\n\\nO João está aguardando você! 😊';\n    novoEstado = 'LINK_ENVIADO';\n  } else if (/^n$|^nao$|^não$|^no$/.test(text)) {\n    resposta = 'Sem problema! Quando quiser agendar, é só responder *sim* aqui. 😊';\n  } else {\n    resposta = 'Para agendar seu Assessment gratuito, responda *sim*.\\nCaso prefira não agendar agora, responda *não*. 📅';\n  }\n\n} else if (estado === 'LINK_ENVIADO') {\n  resposta = 'Obrigado pelo contato, ' + pushName + '! 😊 O João aguarda você no horário escolhido.\\n\\nQualquer dúvida antes da reunião, é só falar aqui!';\n\n} else if (estado === 'HUMAN_TAKEOVER') {\n  resposta = 'Olá, ' + pushName + '! O João Martins foi notificado e entrará em contato em breve. 🤝\\n\\nAgradecemos sua paciência!';\n\n} else {\n  resposta = '';\n}\n\nconst resposta_safe = resposta ? JSON.stringify(resposta).slice(1, -1) : '';\nconst contexto_str  = JSON.stringify(contextoObj);\n\nreturn [{ json: {\n  push_name,\n  phone_raw,\n  session_id:     sessionId,\n  estado_atual:   estado,\n  novo_estado:    novoEstado,\n  contexto_str,\n  resposta,\n  resposta_safe,\n  enviar:         resposta !== '',\n  notificar_dono: notificarDono\n}}];"
      },
      "typeVersion": 2
    },
