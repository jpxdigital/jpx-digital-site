      "parameters": {
        "query": "SELECT s.session_id, s.correlation_id, s.estado, s.contexto::text as contexto, (s.session_id IS NOT NULL)::int as session_found FROM (VALUES (1)) t(x) LEFT JOIN jas_sessions s ON s.telefone = '{{ $('Extrair e Normalizar').item.json.phone }}' AND s.human_takeover = false ORDER BY s.ultima_interacao DESC NULLS LAST LIMIT 1",
        "options": {},
