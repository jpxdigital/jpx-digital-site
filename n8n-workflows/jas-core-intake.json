    {
      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "É mensagem válida?",
      "type": "n8n-nodes-base.if",
      "position": [
        220,
        300
      ],
      "parameters": {
        "options": {},
        "conditions": {
          "options": {
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-event",
              "operator": {
                "name": "filter.operator.equals",
                "type": "string",
                "operation": "equals"
              },
              "leftValue": "={{ $json.body.event }}",
              "rightValue": "messages.upsert"
            }
          ]
        }
      },
      "typeVersion": 2
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000004",
      "name": "Extrair e Normalizar",
      "type": "n8n-nodes-base.code",
      "position": [
        440,
        300
      ],
      "parameters": {
        "jsCode": "const payload = $input.first().json;\nconst _raw = payload.body || payload;\nconst data = _raw.data;\n\nif (!data || !data.key || !data.message) {\n  return [];\n}\n\nconst remoteJid = data.key.remoteJid || '';\nconst isGroup = remoteJid.includes('@g.us');\nif (isGroup) return [];\n\nconst phoneRaw = remoteJid.replace('@s.whatsapp.net', '');\nconst phone = '+' + phoneRaw;\n\nconst messageType = data.messageType || '';\nlet text = '';\nif (messageType === 'conversation') {\n  text = data.message.conversation || '';\n} else if (messageType === 'extendedTextMessage') {\n  text = data.message?.extendedTextMessage?.text || '';\n} else {\n  return [];\n}\n\nif (!text.trim()) return [];\n\nreturn [{\n  json: {\n    phone,\n    phone_raw: phoneRaw,\n    text: text.trim(),\n    push_name: data.pushName || 'Visitante',\n    message_id: data.key.id,\n    message_type: messageType,\n    timestamp: new Date().toISOString(),\n    instance: payload.instance || ''\n  }\n}];"
      },
      "typeVersion": 2
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "Checar Duplicata",
      "type": "n8n-nodes-base.postgres",
      "position": [
        660,
        300
      ],
      "parameters": {
        "query": "SELECT COUNT(*)::int as is_dup FROM jas_message_dedup WHERE message_id = '{{$json.message_id}}'",
        "options": {},
        "operation": "executeQuery"
      },
      "credentials": {
        "postgres": {
          "id": "e5c4827d-4bd0-4a1c-9504-a4a145d93167",
          "name": "JAS PostgreSQL"
        }
      },
      "typeVersion": 2.5
    },
    {
