      ],
      "parameters": {
        "query": "INSERT INTO jas_message_dedup (message_id) VALUES ('{{ $('Extrair e Normalizar').item.json.message_id }}') ON CONFLICT DO NOTHING",
        "options": {},
        "operation": "executeQuery"
      },
      "credentials": {
